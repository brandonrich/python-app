{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DescribeServiceForCurrentTaskDefinition",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeServices"
      ],
      "Resource": "arn:aws:ecs:us-east-1:218705140181:service/python-demo-cluster/python-demo-app"
    },
    {
      "Sid": "DescribeAndRegisterTaskDefinition",
      "Effect": "Allow",
      "Action": [
        "ecs:DescribeTaskDefinition",
        "ecs:RegisterTaskDefinition"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PassTaskRolesToEcsTasks",
      "Effect": "Allow",
      "Action": [
        "iam:PassRole"
      ],
      "Resource": [
        "arn:aws:iam::218705140181:role/*ECSTaskExecutionRole*",
        "arn:aws:iam::218705140181:role/*ECSTaskRole*"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    },
    {
      "Sid": "UpdateServiceToNewTaskDefinition",
      "Effect": "Allow",
      "Action": [
        "ecs:UpdateService"
      ],
      "Resource": "arn:aws:ecs:us-east-1:218705140181:service/python-demo-cluster/python-demo-app"
    }
  ]
}
